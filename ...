{
  "manifest_version": 3,
  "name": "Scratch Booster Pro",
  "version": "2.0",
  "description": "Ultimate tool to boost views, favorites, stars, and followers on Scratch.",
  "permissions": [
    "activeTab",
    "webRequest",
    "https://scratch.mit.edu/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
